{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sokrai.local/contracts/schemas/proposal-source.schema.json",
  "title": "ProposalSource",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "pasted_text",
        "uploaded_file",
        "extracted_text",
        "user_answer",
        "generated_section"
      ]
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "string",
      "minLength": 1
    },
    "section_id": {
      "type": "string",
      "minLength": 1
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_char": {
          "type": "integer",
          "minimum": 0
        },
        "end_char": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "start_char",
        "end_char"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "required": [
    "source_id",
    "source_kind",
    "label",
    "created_at"
  ],
  "oneOf": [
    {
      "properties": {
        "source_kind": {
          "enum": [
            "pasted_text",
            "uploaded_file",
            "extracted_text"
          ]
        }
      },
      "required": [
        "document_id"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "turn_id"
            ]
          },
          {
            "required": [
              "section_id"
            ]
          }
        ]
      }
    },
    {
      "properties": {
        "source_kind": {
          "const": "user_answer"
        }
      },
      "required": [
        "turn_id"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "document_id"
            ]
          },
          {
            "required": [
              "section_id"
            ]
          }
        ]
      }
    },
    {
      "properties": {
        "source_kind": {
          "const": "generated_section"
        }
      },
      "required": [
        "section_id"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "document_id"
            ]
          },
          {
            "required": [
              "turn_id"
            ]
          }
        ]
      }
    }
  ]
}
