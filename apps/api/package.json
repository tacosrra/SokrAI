{
  "name": "@sokrai/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "migrate": "tsx scripts/migrate.ts",
    "test": "vitest run && tsc -p tsconfig.contract-types.json --noEmit",
    "test:contracts": "vitest run ../../tests/contracts && tsc -p tsconfig.contract-types.json --noEmit",
    "test:unit": "vitest run ../../tests/unit",
    "test:integration": "vitest run ../../tests/integration",
    "test:smoke": "vitest run ../../tests/integration/smoke.test.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
