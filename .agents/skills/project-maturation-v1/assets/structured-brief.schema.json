{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/structured-brief.schema.json",
  "title": "StructuredBrief",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "target_user": {
      "type": "string"
    },
    "problem_owner": {
      "type": "string"
    },
    "problem_statement": {
      "type": "string"
    },
    "evidence_of_problem": {
      "type": "string"
    },
    "current_alternatives": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "constraints_known": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_information": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "project_title",
    "goal",
    "target_user",
    "problem_owner",
    "problem_statement",
    "evidence_of_problem",
    "current_alternatives",
    "scope",
    "constraints_known",
    "assumptions",
    "ambiguities",
    "missing_information"
  ]
}
