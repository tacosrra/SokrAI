{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sokrai.local/contracts/schemas/alpha-gap.schema.json",
  "title": "AlphaGap",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "gap_id": {
      "type": "string",
      "minLength": 1
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "string",
      "enum": [
        "problem",
        "solution",
        "data_ai_privacy",
        "medical_device_triage",
        "resources_pilot_viability"
      ]
    },
    "gap_kind": {
      "type": "string",
      "enum": [
        "missing_information",
        "ambiguous_information",
        "unsupported_claim",
        "needs_user_confirmation"
      ]
    },
    "gap_status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "deferred",
        "not_applicable"
      ]
    },
    "origin": {
      "type": "string",
      "enum": [
        "structured_brief_field",
        "structured_brief_missing_information",
        "structured_brief_ambiguity",
        "proposal_source",
        "system_rule"
      ]
    },
    "field": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "absence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "is_absent": {
          "type": "boolean"
        },
        "checked_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "is_absent",
        "checked_fields",
        "reason"
      ]
    },
    "question_hint": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "https://sokrai.local/contracts/schemas/proposal-source.schema.json"
      }
    },
    "resolved_by_turn_id": {
      "type": "string",
      "minLength": 1
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "$ref": "https://sokrai.local/contracts/schemas/audit-ref.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "gap_kind": {
            "const": "missing_information"
          }
        },
        "required": [
          "gap_kind"
        ]
      },
      "then": {
        "properties": {
          "absence": {
            "properties": {
              "is_absent": {
                "const": true
              },
              "checked_fields": {
                "minItems": 1
              },
              "reason": {
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ],
  "required": [
    "gap_id",
    "proposal_id",
    "module",
    "gap_kind",
    "gap_status",
    "origin",
    "field",
    "description",
    "absence",
    "source_refs",
    "audit_refs",
    "warnings",
    "created_at",
    "updated_at"
  ]
}
