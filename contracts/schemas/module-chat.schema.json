{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sokrai.local/contracts/schemas/module-chat.schema.json",
  "title": "ModuleChat",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "chat_id": {
      "type": "string",
      "minLength": 1
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "module": {
      "type": "string",
      "enum": [
        "problem",
        "solution"
      ]
    },
    "chat_status": {
      "type": "string",
      "enum": [
        "not_started",
        "active",
        "waiting_for_user",
        "ready_to_generate",
        "completed",
        "blocked",
        "failed"
      ]
    },
    "turns": {
      "type": "array",
      "items": {
        "$ref": "https://sokrai.local/contracts/schemas/chat-turn.schema.json"
      }
    },
    "active_turn_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "chat_id",
    "proposal_id",
    "module",
    "chat_status",
    "turns",
    "started_at",
    "warnings"
  ]
}
