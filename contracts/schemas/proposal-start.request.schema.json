{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sokrai.local/contracts/schemas/proposal-start.request.schema.json",
  "title": "ProposalStartRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "project_title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "proposal_text": {
      "type": "string",
      "minLength": 1
    },
    "document_text": {
      "type": "string",
      "minLength": 1
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file_name": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "const": "application/pdf"
        },
        "content_base64": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "file_name",
        "mime_type",
        "content_base64"
      ]
    },
    "metadata": {
      "type": "object"
    },
    "specialty": {
      "type": "string",
      "enum": ["default", "legal"]
    }
  },
  "required": [
    "project_title",
    "goal"
  ],
  "anyOf": [
    {
      "required": [
        "proposal_text"
      ]
    },
    {
      "required": [
        "document_text"
      ]
    },
    {
      "required": [
        "file"
      ]
    }
  ]
}
