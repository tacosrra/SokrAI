{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sokrai.local/contracts/schemas/rag-search-request.schema.json",
  "title": "RagSearchRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 8
    }
  },
  "required": ["query", "packs"]
}
