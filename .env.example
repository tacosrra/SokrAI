APP_ENV=local
LOG_LEVEL=info
APP_PORT=3001
APP_BASE_URL=http://localhost:3001
FRONTEND_PORT=3000

# Local controlled-demo configuration only.
# Copy this file to .env or .env.beta for local use; never commit those files.

# Host-side commands use Docker Compose's published Postgres port.
DATABASE_URL=postgresql://sokrai_app:localpass@localhost:5433/sokrai_app
# Integration tests default to the same host-side database unless overridden.
TEST_DATABASE_URL=postgresql://sokrai_app:localpass@localhost:5433/sokrai_app
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=5000

AI_PROVIDER=ollama
# Optional model alias for orchestration. If unset, OLLAMA_MODEL is used.
# AI_MODEL=qwen2.5:3b-instruct
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_MS=900000
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096
BRIEF_EXTRACTION_MAX_CHARS=10000
# Optional DNS overrides for the beta Ollama container if model pulls fail with "no such host".
BETA_OLLAMA_DNS_PRIMARY=1.1.1.1
BETA_OLLAMA_DNS_SECONDARY=8.8.8.8

# Server-side only. Generate real local values and never prefix secrets with VITE_.
INTERNAL_SHARED_SECRET=replace-with-a-random-32-char-secret
JSON_REPAIR_MAX_ATTEMPTS=1
MAX_PROPOSAL_CHARS=30000
MAX_REPLY_CHARS=4000
MAX_TURNS_PER_SESSION=12
MAX_DIAGNOSIS_ITEMS=3
# Clinic demo uses fictitious or anonymized data only. Do not enable for real patient data.
ALLOW_SENSITIVE_HEALTH_DATA=false

N8N_BASIC_AUTH_USER=admin
# Server-side only. Generate a local password and never expose it through VITE_*.
N8N_BASIC_AUTH_PASSWORD=admin
# Keep this stable once n8n has initialized its persisted volume.
# Server-side only. Generate a local key and never expose it through VITE_*.
N8N_ENCRYPTION_KEY=replace-with-a-random-32-char-secret

# n8n local demo retention: avoid persisting execution payloads by default.
# Temporarily change these only when debugging with fake data.
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=none
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=24

# Frontend proxy targets for local Vite / Docker Compose.
API_PROXY_TARGET=http://localhost:3001
WEBHOOK_PROXY_TARGET=http://localhost:5678

# Leave these empty when using the recommended Vite proxy setup.
# VITE_* variables are bundled into browser code. Do not put secrets here.
VITE_API_BASE_URL=
VITE_WEBHOOK_BASE_URL=
VITE_START_SESSION_TIMEOUT_MS=1200000
VITE_REPLY_SESSION_TIMEOUT_MS=960000
VITE_SESSION_AUDIT_TIMEOUT_MS=10000
VITE_REQUEST_STATUS_TIMEOUT_MS=10000
VITE_REQUEST_RECOVERY_TIMEOUT_MS=1200000
VITE_ACTIVE_RECOVERY_AFTER_MS=60000
