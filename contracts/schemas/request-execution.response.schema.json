{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sokrai.local/contracts/schemas/request-execution.response.schema.json",
  "title": "RequestExecutionResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "request_kind": {
      "type": "string",
      "enum": [
        "proposal_start",
        "proposal_reply",
        "solution_start",
        "solution_reply",
        "data_ai_privacy_start",
        "data_ai_privacy_reply",
        "medical_device_triage_start",
        "medical_device_triage_reply",
        "unknown"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed",
        "not_found"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "error_code": {
      "type": "string",
      "minLength": 1
    },
    "safe_message": {
      "type": "string",
      "minLength": 1
    },
    "retryable": {
      "type": "boolean"
    }
  },
  "required": [
    "request_id",
    "request_kind",
    "status"
  ]
}
