# Copia este archivo a `.env.test` en la raíz del repo (gitignored) para las pruebas de integración desde tu PC.
#
# El valor por defecto en `tests/helpers/test-environment.ts` usa localhost:5432;
# con docker-compose de este repo Postgres queda expuesto en el host como 5433.
#
# TEST_DATABASE_URL tiene prioridad sobre DATABASE_URL solo en Vitest (ver tests/vitest-load-env.ts).

TEST_DATABASE_URL=postgresql://sokrai_app:localpass@127.0.0.1:5433/sokrai_app
